        "title": "ユーザー別 Bedrock 呼び出し回数 (合計)",
        "requests": [
          {
            "formulas": [{ "formula": "query1" }],
            "queries": [
              {
                "data_source": "spans",
                "name": "query1",
                "search": { "query": "service:node-lambda-bedrock operation_name:aws.lambda $env" },
                "indexes": ["*"],
                "compute": { "aggregation": "count" },
                "group_by": [
