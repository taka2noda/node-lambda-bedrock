        "requests": [
          {
            "formulas": [
              { "formula": "call_count", "alias": "呼び出し回数", "cell_display_mode": "bar" },
              { "formula": "avg_duration / 1000000", "alias": "平均レイテンシ (ms)" }
            ],
            "queries": [
              {
                "data_source": "spans",
                "name": "call_count",
                "search": { "query": "service:node-lambda-bedrock operation_name:aws.lambda $env" },
                "indexes": ["*"],
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
